# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Only NEXT_PUBLIC_* vars are exposed to the browser.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Observability (added during Day 1)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_SENTRY_DSN=

# Rate limiting (added during Day 1)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----------------------------------------------------------------------------
# Diagnostics — read-only DB access for ad-hoc SELECTs during dev.
# Both are SENSITIVE — bypass RLS, full schema access. Never commit.
# See AGENTS.md "Database — read-only queries are self-service" for usage rules.
# ----------------------------------------------------------------------------

# Supabase project service-role key. Dashboard → Settings → API → service_role.
# Used for: REST admin reads, future scripted backfills.
SUPABASE_SERVICE_KEY=

# Full Postgres connection string for `psql`. Dashboard → Settings → Database →
# Connection string → URI (Session pooler form). Looks like:
#   postgresql://postgres.<ref>:<password>@aws-0-us-west-1.pooler.supabase.com:5432/postgres
# Used for: ad-hoc SELECT / EXPLAIN / pg_get_functiondef during diagnostics.
SUPABASE_DB_URL=
