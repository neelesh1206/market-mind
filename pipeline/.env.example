# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...                # service_role key, NOT anon

# --- Stock data ---
MASSIVE_API_KEY=                            # formerly POLYGON_API_KEY

# --- Free APIs ---
FINNHUB_API_KEY=
FRED_API_KEY=                                # Federal Reserve Economic Data (free, 1k/day)

# --- NLP ---
HUGGINGFACE_API_KEY=
# Override the article summarizer model (default: mistralai/Mistral-7B-Instruct-v0.3).
# Llama-3-8B-Instruct is gated and often requires Pro — Mistral works on free tier.
HUGGINGFACE_SUMMARY_MODEL=

# --- Social ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=marketmind-pipeline/0.1 by u/yourusername

# --- Best-effort scrape (optional) ---
MARKETWATCH_SESSION_COOKIE=                 # leave empty if no subscription

# --- Observability ---
SENTRY_DSN=

# --- Behavior flags ---
PIPELINE_DRY_RUN=false                       # if true, don't write to DB
PIPELINE_LOG_LEVEL=INFO
